# ──────────────────────────────────────────────
# WikINT Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values

# ─── General ───
# Generate a strong SECRET_KEY using: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-string
ENVIRONMENT=development

# ─── PostgreSQL ───
POSTGRES_USER=wikint
POSTGRES_PASSWORD=wikint_dev_password
POSTGRES_DB=wikint
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://wikint:wikint_dev_password@postgres:5432/wikint

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── S3-Compatible Storage ───
# Supports MinIO (dev) and Cloudflare R2 (production).
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_ENDPOINT=minio:9000
# For local development, set this to localhost/s3 to use the Nginx proxy with clean error handling.
# In production with R2, set to your custom domain (e.g., files.yourdomain.com).
S3_PUBLIC_ENDPOINT=localhost/s3
S3_BUCKET=wikint
# Region: "us-east-1" for MinIO, "auto" for Cloudflare R2.
S3_REGION=us-east-1
S3_USE_SSL=false

# ─── Meilisearch ───
MEILI_MASTER_KEY=change-me-to-a-random-key
MEILI_URL=http://meilisearch:7700

# ─── Upload Limits ───
# Maximum file size in MiB. Must also update NEXT_PUBLIC_MAX_FILE_SIZE_MB
# and nginx client_max_body_size if you change this.
MAX_FILE_SIZE_MB=100
NEXT_PUBLIC_MAX_FILE_SIZE_MB=100

# ─── Malware Scanning ───
YARA_RULES_DIR=yara_rules
MALWAREBAZAAR_TIMEOUT=10

# ─── SMTP (email) ───
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@telecom-sudparis.eu
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@telecom-sudparis.eu
SMTP_USE_TLS=true

# ─── JWT ───
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7
JWT_REFRESH_TOKEN_EXPIRE_DAYS=31

# ─── Frontend ───
FRONTEND_URL=http://localhost:3000
# Browser-facing API URL.
# Docker dev (docker-compose.dev.yml): http://localhost/api  — set via compose environment
# Local dev (pnpm dev outside Docker): http://localhost:8000/api
# Production:                          https://yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ─── CORS ───
# Shared between FastAPI and Nginx. Comma-separated, no spaces.
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Client-ID,Accept,X-Requested-With

# ─── ONLYOFFICE Document Server ───
# JWT secret shared between the API and ONLYOFFICE Document Server.
# Must match JWT_SECRET set on the onlyoffice container.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ONLYOFFICE_JWT_SECRET=insecure-dev-only-onlyoffice-secret
# Separate secret for file-access tokens (API-only, NOT shared with OnlyOffice).
# Must differ from ONLYOFFICE_JWT_SECRET. Generate a distinct value.
ONLYOFFICE_FILE_TOKEN_SECRET=insecure-dev-only-onlyoffice-file-token-secret
# Browser-facing URL for loading the ONLYOFFICE JS API (served via nginx proxy).
# In Docker dev, nginx proxies /onlyoffice/ → onlyoffice:80.
NEXT_PUBLIC_ONLYOFFICE_URL=http://localhost/onlyoffice
# Internal URL used by the ONLYOFFICE container to fetch files from the API.
ONLYOFFICE_INTERNAL_API_BASE_URL=http://api:8000

# ─── Nginx ───
DOMAIN=localhost
