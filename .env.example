# ──────────────────────────────────────────────
# WikINT Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#
# IMPORTANT: Most application settings (Storage, Email, Authentication,
# Branding, and Limits) are managed via the Admin Dashboard once the
# platform is running. These environment variables are only for
# infrastructure and core service connectivity.

# ─── General ───
# Generate a strong SECRET_KEY using: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-string
ENVIRONMENT=development

# ─── PostgreSQL ───
POSTGRES_USER=wikint
POSTGRES_PASSWORD=wikint_dev_password
POSTGRES_DB=wikint
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Used by the API to connect to the database
DATABASE_URL=postgresql+asyncpg://wikint:wikint_dev_password@postgres:5432/wikint

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── Meilisearch ───
MEILI_MASTER_KEY=change-me-to-a-random-key
# Search-only key for the public search route. Provision via Meilisearch admin API.
MEILI_SEARCH_KEY=change-me-to-a-random-search-key
MEILI_URL=http://meilisearch:7700

# ─── Malware Scanning ───
YARA_RULES_DIR=yara_rules
MALWAREBAZAAR_TIMEOUT=10
# Optional: API key for MalwareBazaar to avoid higher rate limits
# MALWAREBAZAAR_API_KEY=your-api-key-here
# Whether a MalwareBazaar error should block the upload (fail-closed)
MALWAREBAZAAR_FAIL_CLOSED=false

# ─── ONLYOFFICE Document Server ───
# JWT secret shared between the API and ONLYOFFICE Document Server.
ONLYOFFICE_JWT_SECRET=insecure-dev-only-onlyoffice-secret
# Separate secret for file-access tokens (API-only, NOT shared with OnlyOffice).
ONLYOFFICE_FILE_TOKEN_SECRET=insecure-dev-only-onlyoffice-file-token-secret
# Internal URL used by the ONLYOFFICE container to fetch files from the API.
ONLYOFFICE_INTERNAL_API_BASE_URL=http://api:8000

# ─── Network & Frontend ───
# The domain where the application is hosted (e.g., wikint.example.com)
DOMAIN=localhost
FRONTEND_URL=http://localhost:3000

# Browser-facing API URL. Defaults to /api.
NEXT_PUBLIC_API_URL=/api
# Browser-facing URL for ONLYOFFICE. Defaults to /onlyoffice.
NEXT_PUBLIC_ONLYOFFICE_URL=http://localhost/onlyoffice
# S3 public domain used by Nginx proxy in production.
S3_PUBLIC_DOMAIN=files.wikint.hypnos2026.fr

# ─── CORS ───
# Shared between FastAPI and Nginx. Comma-separated, no spaces.
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Client-ID,Accept,X-Requested-With
