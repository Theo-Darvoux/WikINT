# ──────────────────────────────────────────────
# WikINT Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values

# ─── General ───
# Generate a strong SECRET_KEY using: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-string
ENVIRONMENT=development

# ─── PostgreSQL ───
POSTGRES_USER=wikint
POSTGRES_PASSWORD=wikint_dev_password
POSTGRES_DB=wikint
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://wikint:wikint_dev_password@postgres:5432/wikint

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── MinIO (S3-compatible) ───
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
# For local development, set this to localhost/s3 to use the Nginx proxy with clean error handling.
# In production, this should be your domain (e.g., yourdomain.com/s3).
MINIO_PUBLIC_ENDPOINT=localhost/s3
MINIO_BUCKET=wikint
MINIO_USE_SSL=false

# ─── Meilisearch ───
MEILI_MASTER_KEY=change-me-to-a-random-key
MEILI_URL=http://meilisearch:7700

# ─── Upload Limits ───
# Maximum file size in MiB. Must also update NEXT_PUBLIC_MAX_FILE_SIZE_MB,
# nginx client_max_body_size, and ClamAV StreamMaxLength if you change this.
MAX_FILE_SIZE_MB=100
NEXT_PUBLIC_MAX_FILE_SIZE_MB=100

# ─── ClamAV ───
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_SCAN_TIMEOUT_BASE=60
CLAMAV_SCAN_TIMEOUT_PER_GB=120

# ─── SMTP (email) ───
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@telecom-sudparis.eu
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@telecom-sudparis.eu
SMTP_USE_TLS=true

# ─── JWT ───
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7
JWT_REFRESH_TOKEN_EXPIRE_DAYS=31

# ─── Frontend ───
FRONTEND_URL=http://localhost:3000
# Browser-facing API URL.
# Docker dev (docker-compose.dev.yml): http://localhost/api  — set via compose environment
# Local dev (pnpm dev outside Docker): http://localhost:8000/api
# Production:                          https://yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ─── Nginx ───
DOMAIN=localhost
