worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /var/run/nginx.pid;

events {
    worker_connections 1024;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      close;
    }

    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                    '$status $body_bytes_sent "$http_referer" '
                    '"$http_user_agent" "$http_x_forwarded_for"';

    access_log /var/log/nginx/access.log main;

    sendfile on;
    keepalive_timeout 65;
    client_max_body_size 500m;

    upstream api {
        server api:8000;
    }

    upstream web {
        server web:3000;
    }

    upstream onlyoffice {
        server onlyoffice:80;
    }

    upstream minio {
        server minio:9000;
    }

    server {
        listen 80;
        server_name _;

        # API requests
        location /api/ {
            proxy_pass http://api;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
        }

        # ONLYOFFICE / Euro-Office Routing Logic

        # A. Global catch-all for versioned paths (handles redirects that strip /onlyoffice/)
        location ~* ^/(\d+\.\d+\.\d+[\.-][a-zA-Z0-9]+)/ {
            set $onlyoffice_upstream http://onlyoffice;
            proxy_pass $onlyoffice_upstream;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Host $host;
            proxy_buffering off;
            proxy_read_timeout 3600s;
        }
        
        # B. Specific fix for themes.json
        location ~* ^/(onlyoffice/)?(\d+\.\d+\.\d+[\.-][a-zA-Z0-9]+)/themes.json$ {
            set $onlyoffice_upstream http://onlyoffice;
            rewrite ^ /web-apps/apps/themes/themes.json break;
            proxy_pass $onlyoffice_upstream;
            proxy_set_header Host $host;
        }

        # C. Main OnlyOffice block with prefix
        location /onlyoffice/ {
            set $onlyoffice_upstream http://onlyoffice;
            rewrite ^/onlyoffice/(.*)$ /$1 break;
            
            proxy_pass $onlyoffice_upstream;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Host $host;
            
            # WebSocket and performance optimizations
            proxy_buffering off;
            proxy_request_buffering off;
            proxy_cache off;
            gzip off;
            proxy_read_timeout 3600s;
            proxy_send_timeout 3600s;
            proxy_connect_timeout 60s;

            # Ensure redirects from OnlyOffice include the /onlyoffice/ prefix
            proxy_redirect / /onlyoffice/;

            # Allow internal redirects and capture errors
            proxy_intercept_errors on;
            error_page 404 = @nextjs_fallback;
        }

        # D. Non-versioned OnlyOffice asset and cache paths
        location ~* ^/(cache|web-apps|sdkjs|sdkjs-plugins|fonts|dictionaries|meta|printfile)/ {
            set $onlyoffice_upstream http://onlyoffice;
            proxy_pass $onlyoffice_upstream;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_buffering off;
            proxy_read_timeout 3600s;
            proxy_intercept_errors on;
            error_page 404 = @nextjs_fallback;
        }

        # E. Direct API access (some versions use /doc/ or /coauthoring/ without version hash)
        location ~* ^/(doc|coauthoring|downloadas|command|status|history|shards)/ {
            set $onlyoffice_upstream http://onlyoffice;
            proxy_pass $onlyoffice_upstream;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_buffering off;
            proxy_read_timeout 3600s;
        }

        # Deny access to ONLYOFFICE internal and admin paths
        location ~* ^/(converter|healthcheck)/ {
            return 403;
        }

        # Main Frontend Application
        location / {
            proxy_pass http://web;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            proxy_read_timeout 300s;
            proxy_send_timeout 300s;
            proxy_connect_timeout 300s;
        }

        # Fallback for paths that matched the ONLYOFFICE regex but returned 404.
        location @nextjs_fallback {
            proxy_pass http://web;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            proxy_read_timeout 300s;
            proxy_send_timeout 300s;
            proxy_connect_timeout 300s;
        }

        # Explicitly handle Next.js HMR
        location ~ ^/_next/(webpack-hmr|hmr) {
            proxy_pass http://web;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            proxy_set_header Host $host;
            proxy_cache_bypass $http_upgrade;
        }

        # S3 Proxy with clean error handling
        location /s3/ {
            proxy_pass http://minio/;
            proxy_set_header Host "minio:9000";
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            add_header X-Content-Type-Options "nosniff" always;
            proxy_intercept_errors on;
            error_page 403 =403 /error-expired.html;
        }

        location = /error-expired.html {
            root /etc/nginx/html;
            internal;
        }
    }
}
